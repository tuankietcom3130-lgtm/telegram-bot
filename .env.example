# ==========================================
# FILE CẤU HÌNH MẪU (.env.example)
# Đổi tên file này thành .env và điền thông tin thật của bạn vào trước khi chạy Bot.
# TUYỆT ĐỐI KHÔNG ĐƯỢC ĐẨY FILE .env LÊN GITHUB!
# ==========================================

# 1. KẾT NỐI BOT
BOT_TOKEN=điền_token_bot_của_bạn_vào_đây

# 2. CẤU HÌNH NHÓM VÀ KÊNH
# ID của Kênh và Nhóm (luôn là số âm, kênh/nhóm thường bắt đầu bằng -100)
CHANNEL_ID=-100xxxxxxxxxx
GROUP_ID=-100xxxxxxxxxx

# Link để người dùng bấm vào tham gia (Không bắt buộc phải có @, dùng link t.me)
CHANNEL_URL=https://t.me/link_kenh_cua_ban
GROUP_URL=https://t.me/link_nhom_cua_ban

# 3. QUẢN TRỊ VIÊN (ADMIN)
# Lấy ID bằng cách nhắn tin cho @userinfobot
ADMIN_ID=điền_dãy_số_id_của_bạn_vào_đây
# Username không cần chứa dấu @ ở đầu
ADMIN_USERNAME=username_cua_ban

# 4. FILE ID MEDIA (Tự động lấy khi admin gửi file/ảnh/video cho bot)
GUIDE_VIDEO_ID=điền_file_id_cua_video_huong_dan_vao_day
DONATE_IMAGE_ID=điền_file_id_cua_anh_donate_vao_day

# 5. DATABASE (Ghi chú)
# DATABASE_URL= (Không cần sử dụng nữa vì Bot bản mới đã lưu dữ liệu nội bộ trực tiếp trên ổ cứng VPS)

